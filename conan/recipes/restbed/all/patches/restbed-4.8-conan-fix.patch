--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -39,6 +39,10 @@ if( ${CMAKE_CXX_COMPILER_ID} STREQUAL MSVC )
     set( CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} /D_WIN32_WINNT=0x0601 /W4 /wd4068 /wd4702 /wd4996 /wd4265" )
 endif ( )
 
+if ( CMAKE_SYSTEM_NAME MATCHES "QNX" )
