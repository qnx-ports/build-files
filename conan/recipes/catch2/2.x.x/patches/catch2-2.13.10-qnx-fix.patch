diff --git a/include/internal/catch_debugger.cpp b/include/internal/catch_debugger.cpp
index d4f74780..669f27e9 100644
--- a/include/internal/catch_debugger.cpp
+++ b/include/internal/catch_debugger.cpp
@@ -101,6 +101,39 @@
             return false;
         }
     } // namespace Catch
+#elif defined(CATCH_PLATFORM_QNX)
+    #include <devctl.h>
+    #include <fcntl.h>
+    #include <sys/procfs.h>
+    #include <unistd.h>
+
+    namespace Catch {
+        bool isDebuggerActive() {
+            const int fd = ::open("/proc/self/ctl", O_RDONLY);
+            if (fd == -1) {
+                return false;
+            }
+
+            procfs_status status{};
+            const int rc = ::devctl(fd, DCMD_PROC_STATUS, &status, sizeof(status), nullptr);
+            ::close(fd);
+
+            if (rc != EOK) {
+                return false;
+            }
+
+            // Best-effort QNX heuristic:
+            // - STOPPED/ISTOP/SSTEP/TRACE_EXEC strongly suggest debugger control
+            // - RLC/KLC are debugger-related process flags and are also useful hints
+            const uint32_t f = status.flags;
+            return (f & (_DEBUG_FLAG_STOPPED |
+                        _DEBUG_FLAG_ISTOP |
+                        _DEBUG_FLAG_SSTEP |
+                        _DEBUG_FLAG_TRACE_EXEC |
+                        _DEBUG_FLAG_RLC |
+                        _DEBUG_FLAG_KLC)) != 0;
+        }
+    } // namespace Catch
 #elif defined(_MSC_VER)
     extern "C" __declspec(dllimport) int __stdcall IsDebuggerPresent();
     namespace Catch {
