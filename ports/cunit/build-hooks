#!/bin/sh

# Path from build dir to source root
NESTED_LEVEL="${QNX_PROJECT_ROOT:-../../..}"

# Default prefix inside QNX target sysroot
BASIC_PREFIX="/usr/local"
EXEC_PREFIX="/${cpudir}${BASIC_PREFIX}"

function hook_preconfigure {
    echo "hook_preconfigure - running autoreconf in ${NESTED_LEVEL}"

    # Unset any conflicting autoconf tool variables
    unset AUTOMAKE AUTOCONF AUTOHEADER AUTORECONF ACLOCAL

    # Set DESTDIR for staged installs
    export DESTDIR="${INSTALL_ROOT_nto}"
    
    # Set CFLAGS that configure will use
    export CFLAGS="-O2 -Wall -Wno-format -Wno-unused-but-set-variable"

    (cd "${NESTED_LEVEL}" && {
        echo "  Cleaning Autotools generated files..."
        rm -f config.status config.log config.cache Makefile Makefile.in
        rm -f config.h config.h.in libtool *.la *.lo *.o *.a *.so
        rm -f aclocal.m4 ltmain.sh stamp-h* stamp-h1
        rm -rf autom4te.cache
        
        # Remove ALL Makefiles recursively
        rm -f */Makefile */*/Makefile */*/*/Makefile
        
        # Remove ALL .deps recursively
        rm -rf .deps */.deps */*/.deps */*/*/.deps
        
        echo "Source tree cleaned of Autotools generated files."
    })

    #regenerate configure and Makefile.in files
    (cd "${NESTED_LEVEL}" && autoreconf -fiv)

}

function hook_configure {
    echo "hook_configure - running configure"
    # Force clean before every configure
    rm -f "${NESTED_LEVEL}/config.status"

    "${NESTED_LEVEL}/configure" \
        --srcdir="${NESTED_LEVEL}" \
        --prefix="${BASIC_PREFIX}" \
        --exec-prefix="${EXEC_PREFIX}" \
        --host="${machine}" \
        --enable-debug \
        --enable-examples \
        --enable-automated \
        --enable-basic \
        --enable-test \
        --disable-static \
        CPPFLAGS="\
        -I${NESTED_LEVEL}/CUnit/Headers \
        -I${NESTED_LEVEL}/CUnit/Sources/Framework \
        -I${NESTED_LEVEL}/CUnit/Sources/Test \
        -I${NESTED_LEVEL}/Examples \
        ${CPPFLAGS}"
}

function hook_make {
    echo "hook_make - running make ${make_cmds}"

    INSTALL_ROOT="${INSTALL_ROOT_nto}"

    if [ "${make_cmds}" = "install" ]; then
        make ${JLEVEL:+-j${JLEVEL}} all || exit 1
        make ${JLEVEL:+-j${JLEVEL}} install-exec || exit 1
        # Clean up .la files
        find "${INSTALL_ROOT_nto}" -name "*.la" -exec rm -f {} \;
    else
        make ${JLEVEL:+-j${JLEVEL}} ${make_cmds} || exit 1
    fi
}
