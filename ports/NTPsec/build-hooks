#!/bin/sh

NESTED_LEVEL="${QNX_PROJECT_ROOT:-../../..}"
BASIC_PREFIX="/usr/local"
EXEC_PREFIX="/${cpudir}${BASIC_PREFIX}"

function hook_preconfigure {
    echo "hook_preconfigure - running in ${NESTED_LEVEL}"

    unset AUTOMAKE AUTOCONF AUTOHEADER AUTORECONF ACLOCAL
    export DESTDIR="${INSTALL_ROOT_nto}"

    if [ ! -f "${NESTED_LEVEL}/wscript" ]; then
        echo "ERROR: wscript not found in ${NESTED_LEVEL}"
        exit 1
    fi

    if [ ! -f "${NESTED_LEVEL}/waf" ]; then
        echo "ERROR: waf script not found in ${NESTED_LEVEL}"
        exit 1
    fi
}

function hook_configure {
    echo "hook_configure - waf configure"  
      
    export PKG_CONFIG_LIBDIR=${DESTDIR}/usr/local/lib/pkgconfig  
    cd "${NESTED_LEVEL}" || exit 1  

    case "${cpudir}" in  
        aarch64le)  
            TARGET_CC="aarch64-unknown-nto-qnx7.1.0-gcc"
            ;;  
        x86_64)  
            TARGET_CC="x86_64-pc-nto-qnx7.1.0-gcc"  
            ;;  
        *)  
            echo "ERROR: Unknown architecture ${cpudir}"  
            exit 1  
            ;;  
    esac 
    # Capture the QNX target flags before unsetting them
    TARGET_CFLAGS="${CFLAGS}"  
    TARGET_LDFLAGS="${LDFLAGS} -lsocket -lm"  

    unset AR LD CPPFLAGS

export CC="${TARGET_CC}"
export CFLAGS="${TARGET_CFLAGS}"
export LDFLAGS="${TARGET_LDFLAGS}"

    echo "TARGET_CC=${TARGET_CC}"  
    echo "TARGET_CFLAGS=${TARGET_CFLAGS}"  
    echo "TARGET_LDFLAGS=${TARGET_LDFLAGS}"
  
    # IMPORTANT: Unset target-polluted variables so 'host' variant uses native tools  
    unset CC CFLAGS LDFLAGS CPPFLAGS AR LD  
  
    ./waf configure \
        --prefix="${EXEC_PREFIX}" \
        --cross-compiler="${TARGET_CC}" \
        --cross-cflags="${TARGET_CFLAGS}" \
        --cross-ldflags="${TARGET_LDFLAGS}" \
        --disable-mdns-registration \
        || exit 1  
}

function hook_make {
    echo "hook_make - ${make_cmds}"

    cd "${NESTED_LEVEL}" || exit 1

    if [ "${make_cmds}" = "install" ]; then
        ./waf install --destdir=${INSTALL_ROOT_nto} || exit 1

    elif [ "${make_cmds}" = "clean" ]; then
        ./waf clean || exit 1

    else
        ./waf build || exit 1
    fi
    
}
